{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist/main",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*",
    "src/agent/**/*",
    "src/memory/**/*",
    "src/skills/**/*",
    "src/tools/**/*",
    "src/integrations/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
